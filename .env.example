# Frontend env vars (Vite). Copy this file to `.env` to override defaults.
# Production default (baked into the built bundle) lives in src/components/Chatbot/Chatbot.jsx.

# Production backend (default — used by ponda.fun):
VITE_CHATBOT_API=https://mista-ponda-jbl2.vercel.app

# For local backend dev, comment the line above and use:
# VITE_CHATBOT_API=http://localhost:8000
